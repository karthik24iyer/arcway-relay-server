# ─── Required ─────────────────────────────────────────────────────────────────

# Domain pointing at this host. Caddy obtains a Let's Encrypt cert automatically
# on first boot. Ports 80 and 443 must be reachable from the internet.
DOMAIN=relay.example.com

# ─── Optional ─────────────────────────────────────────────────────────────────

# Auth method exposed to clients.
#   'pair'  (default) — self-host. /auth/pair endpoints; Google/Apple disabled.
#   'oauth'           — hosted multi-tenant. /auth/google, /auth/apple endpoints;
#                       pair disabled. Requires GOOGLE_CLIENT_ID (and Apple env if used).
# AUTH_MODE=pair

# Override the auto-generated pair code (default: random 6 chars at /data/.relay-code).
# Only used when AUTH_MODE=pair.
# RELAY_CODE=XK3F9P

# Restrict features on this instance. Absence = no restriction.
# OSS_POLICY='{"max_sessions": 3, "voice_enabled": false}'
