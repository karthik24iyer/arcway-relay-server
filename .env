# Domain pointing at this host. Caddy obtains a Let's Encrypt cert automatically
# on first boot. Ports 80 and 443 must be reachable from the internet.
DOMAIN=relay.example.com

# ── Advanced overrides (uncomment only if you need them) ─────────────────────

# Listen port (relay's HTTP/WS). Caddy maps :443 → :3000 in the compose stack.
# PORT=3000

# SQLite file path. Defaults to data/relay.db (./data when run from source,
# /data inside the Docker image).
# SQLITE_PATH=./data/relay.db

# Comma-separated CORS allowlist for the HTTP API. Leave unset for "any origin".
# ALLOWED_ORIGINS=https://yourapp.example.com
